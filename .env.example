# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ECR Repository
ECR_REPOSITORY_URL=your-account-id.dkr.ecr.us-east-1.amazonaws.com/your-repo-name
IMAGE_TAG=latest

# Docker Container Configuration
CONTAINER_NAME=myapp
CONTAINER_PORT=80
HOST_PORT=80

# Docker Environment Variables (comma-separated)
DOCKER_ENV_VARS=APP_ENV=production,DEBUG=false,PORT=80,DATABASE_URL=your-db-url,API_KEY=your-api-key
